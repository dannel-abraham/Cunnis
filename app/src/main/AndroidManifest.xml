<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".CunnisApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Cunnis"
        android:largeHeap="true"
        tools:targetApi="34">

        <!-- Splash Activity -->
        <activity
            android:name=".ui.activity.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Cunnis.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Profile Setup Activity -->
        <activity
            android:name=".ui.activity.ProfileSetupActivity"
            android:exported="false"
            android:theme="@style/Theme.Cunnis" />

        <!-- Main Activity -->
        <activity
            android:name=".ui.activity.MainActivity"
            android:exported="false" />

        <!-- Add/Edit Cage -->
        <activity
            android:name=".ui.activity.AddEditCageActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.MainActivity" />

        <!-- Add/Edit Rabbit -->
        <activity
            android:name=".ui.activity.AddEditRabbitActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- Rabbit Detail -->
        <activity
            android:name=".ui.activity.RabbitDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.MainActivity" />

        <!-- Add Health Event -->
        <activity
            android:name=".ui.activity.HealthEventActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.RabbitDetailActivity" />

        <!-- Add Mating Record -->
        <activity
            android:name=".ui.activity.MatingRecordActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.RabbitDetailActivity" />

        <!-- Add Parturition Record -->
        <activity
            android:name=".ui.activity.ParturitionRecordActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.RabbitDetailActivity" />

        <!-- Add Weight Record -->
        <activity
            android:name=".ui.activity.WeightRecordActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.RabbitDetailActivity" />

        <!-- Add Expense -->
        <activity
            android:name=".ui.activity.AddExpenseActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.MainActivity" />

        <!-- Add Feeding -->
        <activity
            android:name=".ui.activity.AddFeedingActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.MainActivity" />

        <!-- Export/Import -->
        <activity
            android:name=".ui.activity.ExportImportActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.MainActivity" />

        <!-- Settings -->
        <activity
            android:name=".ui.activity.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.MainActivity" />

        <!-- Cage Detail -->
        <activity
            android:name=".ui.activity.CageDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.MainActivity" />

        <!-- Rabbit Stats -->
        <activity
            android:name=".ui.activity.RabbitStatsActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.RabbitDetailActivity" />

        <!-- Alert Receiver -->
        <receiver
            android:name=".receiver.AlertReceiver"
            android:exported="false" />

        <!-- File Provider for camera -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>

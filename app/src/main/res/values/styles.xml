<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dialog themes -->
    <style name="ThemeOverlay.Cunnis.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="colorPrimary">@color/cunnis_control_normal</item>
        <item name="colorSecondary">@color/cunnis_accent</item>
    </style>
    <style name="ThemeOverlay.Cunnis.Dialog.Dark" parent="ThemeOverlay.Material3.Dialog">
        <item name="colorPrimary">@color/cunnis_primary</item>
        <item name="colorSecondary">@color/cunnis_accent</item>
    </style>

    <!-- Bottom Sheet -->
    <style name="ThemeOverlay.Cunnis.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="colorPrimary">@color/cunnis_control_normal</item>
    </style>
    <style name="ThemeOverlay.Cunnis.BottomSheetDialog.Dark" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="colorPrimary">@color/cunnis_primary</item>
    </style>

    <!-- Card styles -->
    <style name="Widget.Cunnis.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="Widget.Cunnis.Card.Cage" parent="Widget.Cunnis.Card">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">3dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
    </style>

    <style name="Widget.Cunnis.Card.Rabbit" parent="Widget.Cunnis.Card">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="Widget.Cunnis.Card.Stat" parent="Widget.Cunnis.Card">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">1dp</item>
        <item name="contentPadding">12dp</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.Cunnis.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Cunnis.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/cunnis_control_normal</item>
        <item name="android:textColor">@color/cunnis_white</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Cunnis.Button.Accent" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/cunnis_accent</item>
        <item name="android:textColor">@color/cunnis_white</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Cunnis.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/cunnis_control_normal</item>
        <item name="android:textColor">@color/cunnis_control_normal</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Cunnis.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="tint">@color/cunnis_white</item>
        <item name="backgroundTint">@color/cunnis_control_normal</item>
    </style>

    <!-- Input styles -->
    <style name="Widget.Cunnis.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">?attr/colorPrimary</item>
    </style>

    <style name="Widget.Cunnis.TextInputLayout.ExposedDropdownMenu" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">?attr/colorPrimary</item>
    </style>

    <!-- Chip styles -->
    <style name="Widget.Cunnis.Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">8dp</item>
    </style>

    <style name="Widget.Cunnis.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">8dp</item>
        <item name="chipBackgroundColor">@color/cunnis_control_highlight</item>
    </style>

    <!-- AppBar -->
    <style name="Widget.Cunnis.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/TextAppearance.Cunnis.TitleLarge</item>
    </style>

    <!-- Navigation -->
    <style name="Widget.Cunnis.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemPaddingTop">4dp</item>
        <item name="itemPaddingBottom">4dp</item>
    </style>

    <!-- Badge -->
    <style name="Widget.Cunnis.Badge" parent="Widget.Material3.Badge">
        <item name="backgroundColor">@color/cunnis_accent</item>
        <item name="badgeTextColor">@color/cunnis_white</item>
    </style>

    <!-- Snackbar -->
    <style name="Widget.Cunnis.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="android:textColorPrimaryInverse">@color/cunnis_white</item>
    </style>

    <!-- ProgressBar -->
    <style name="Widget.Cunnis.ProgressBar.Indeterminate" parent="Widget.Material3.LinearProgressIndicator">
        <item name="trackColor">?attr/colorSurfaceVariant</item>
        <item name="indicatorColor">?attr/colorPrimary</item>
    </style>

    <!-- Tab layout -->
    <style name="Widget.Cunnis.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/cunnis_control_normal</item>
        <item name="tabSelectedTextColor">@color/cunnis_control_normal</item>
        <item name="tabTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="tabIndicatorHeight">3dp</item>
    </style>
</resources>

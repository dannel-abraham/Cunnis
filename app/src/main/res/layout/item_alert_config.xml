<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Cunnis.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/margin_small">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_small">

        <!-- Top row: name and toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txtAlertName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/TextAppearance.Cunnis.TitleMedium" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAlertEnabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Description -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/txtAlertDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Cunnis.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="@dimen/margin_small"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Advance days -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/txtAdvanceDays"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Cunnis.LabelSmall"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="@dimen/margin_small" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

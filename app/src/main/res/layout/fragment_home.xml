<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_medium">

            <!-- Welcome Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWelcome"
                style="@style/Widget.Cunnis.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/cunnis_control_normal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/txtWelcome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/home_welcome"
                        style="@style/TextAppearance.Cunnis.HeadlineSmall"
                        android:textColor="@color/cunnis_white" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/txtFarmName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#B0FFFFFF"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Stats Grid -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_total"
                style="@style/TextAppearance.Cunnis.TitleMedium"
                android:layout_marginBottom="@dimen/margin_small" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/margin_medium">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Cunnis.Card.Stat"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/stat_card_height"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/margin_small">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txtTotalRabbits"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            style="@style/TextAppearance.Cunnis.HeadlineLarge"
                            android:textColor="@color/cunnis_control_normal" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_total"
                            style="@style/TextAppearance.Cunnis.BodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Cunnis.Card.Stat"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/stat_card_height"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/margin_small"
                    android:layout_marginEnd="@dimen/margin_small">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txtMales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            style="@style/TextAppearance.Cunnis.HeadlineLarge"
                            android:textColor="@color/cunnis_male" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_males"
                            style="@style/TextAppearance.Cunnis.BodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Cunnis.Card.Stat"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/stat_card_height"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/margin_small">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txtFemales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            style="@style/TextAppearance.Cunnis.HeadlineLarge"
                            android:textColor="@color/cunnis_female" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_females"
                            style="@style/TextAppearance.Cunnis.BodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Cages Count Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/margin_medium">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Cunnis.Card.Stat"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/stat_card_height"
                    android:layout_weight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txtCageCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            style="@style/TextAppearance.Cunnis.HeadlineLarge"
                            android:textColor="@color/cunnis_cemental" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_cages"
                            style="@style/TextAppearance.Cunnis.BodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

            </LinearLayout>

            <!-- Quick Actions -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_quick_actions"
                style="@style/TextAppearance.Cunnis.TitleMedium"
                android:layout_marginBottom="@dimen/margin_small"
                android:layout_marginTop="@dimen/margin_small" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Cunnis.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_small">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddRabbit"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/home_add_rabbit"
                        android:gravity="start|center_vertical"
                        android:textAlignment="textStart"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconTint="@color/cunnis_control_normal" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddCage"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/home_add_cage"
                        android:gravity="start|center_vertical"
                        android:textAlignment="textStart"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconTint="@color/cunnis_control_normal" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRecordMating"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/home_record_mating"
                        android:gravity="start|center_vertical"
                        android:textAlignment="textStart"
                        app:icon="@android:drawable/ic_menu_add"
                        app:iconTint="@color/cunnis_accent" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddExpense"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/home_add_expense"
                        android:gravity="start|center_vertical"
                        android:textAlignment="textStart"
                        app:icon="@drawable/ic_expense"
                        app:iconTint="@color/cunnis_error" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Pending Alerts Section -->
            <LinearLayout
                android:id="@+id/layoutPendingAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/margin_medium"
                android:visibility="gone">

                <!-- Section header with View All -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/margin_small">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/home_pending_alerts"
                        style="@style/TextAppearance.Cunnis.TitleMedium" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewAllAlerts"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_view_all_alerts"
                        android:textColor="@color/cunnis_control_normal"
                        android:minHeight="36dp" />

                </LinearLayout>

                <!-- Alert stat cards row -->
                <LinearLayout
                    android:id="@+id/layoutAlertCards"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <!-- Estrus card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardEstrusAlert"
                        style="@style/Widget.Cunnis.Card.Stat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/margin_small"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_female"
                                app:tint="@color/cunnis_female"
                                android:layout_marginBottom="4dp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txtEstrusCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                style="@style/TextAppearance.Cunnis.HeadlineSmall"
                                android:textColor="@color/cunnis_female" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/alert_estrus"
                                style="@style/TextAppearance.Cunnis.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:maxLines="2"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Gestation card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardGestationAlert"
                        style="@style/Widget.Cunnis.Card.Stat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/margin_small"
                        android:layout_marginEnd="@dimen/margin_small"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_born"
                                app:tint="@color/cunnis_warning"
                                android:layout_marginBottom="4dp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txtGestationCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                style="@style/TextAppearance.Cunnis.HeadlineSmall"
                                android:textColor="@color/cunnis_warning" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/alert_gestation"
                                style="@style/TextAppearance.Cunnis.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:maxLines="2"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Weaning card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardWeaningAlert"
                        style="@style/Widget.Cunnis.Card.Stat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/margin_small"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_warning"
                                app:tint="@color/cunnis_accent"
                                android:layout_marginBottom="4dp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txtWeaningCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                style="@style/TextAppearance.Cunnis.HeadlineSmall"
                                android:textColor="@color/cunnis_accent" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/alert_weaning"
                                style="@style/TextAppearance.Cunnis.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:maxLines="2"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- No alerts message -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtNoAlerts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_no_pending_alerts"
                    style="@style/TextAppearance.Cunnis.BodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:paddingTop="@dimen/padding_small"
                    android:paddingBottom="@dimen/padding_small"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

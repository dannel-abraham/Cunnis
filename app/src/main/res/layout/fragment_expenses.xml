<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Total Expenses Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTotal"
            style="@style/Widget.Cunnis.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_medium"
            app:cardBackgroundColor="@color/cunnis_control_normal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/padding_medium">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Cunnis.BodyMedium"
                    android:text="@string/expenses_total_label"
                    android:textColor="#B0FFFFFF" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtTotalAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Cunnis.HeadlineLarge"
                    android:textColor="@color/cunnis_white"
                    android:text="$0.00" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Filter Chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/margin_medium"
            android:paddingEnd="@dimen/margin_medium"
            android:paddingBottom="@dimen/margin_small"
            app:singleLine="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                style="@style/Widget.Cunnis.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/expenses_filter_all"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFeed"
                style="@style/Widget.Cunnis.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/expense_feed" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMedicine"
                style="@style/Widget.Cunnis.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/expense_medicine" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEquipment"
                style="@style/Widget.Cunnis.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/expense_equipment" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVeterinary"
                style="@style/Widget.Cunnis.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/expense_veterinary" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTransport"
                style="@style/Widget.Cunnis.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/expense_transport" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Expenses List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="@dimen/margin_medium"
            android:paddingEnd="@dimen/margin_medium" />

        <!-- Empty State -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/txtEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="@string/expenses_empty"
            style="@style/TextAppearance.Cunnis.BodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        style="@style/Widget.Cunnis.FloatingActionButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/fab_margin"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="@string/expense_add" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

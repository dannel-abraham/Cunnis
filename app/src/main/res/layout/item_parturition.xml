<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Cunnis.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/margin_small"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_medium">

        <!-- Header: date + complications icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txtDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/TextAppearance.Cunnis.TitleMedium" />

            <ImageView
                android:id="@+id/imgComplications"
                android:layout_width="@dimen/icon_size_small"
                android:layout_height="@dimen/icon_size_small"
                android:src="@android:drawable/ic_dialog_alert"
                app:tint="@color/cunnis_error"
                android:contentDescription="@string/parturition_complications"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Estimated weaning date -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/txtWeaningDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            style="@style/TextAppearance.Cunnis.LabelSmall"
            android:textColor="?attr/colorPrimary"
            android:visibility="gone" />

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/margin_small"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="@dimen/padding_small"
                android:background="?attr/colorSurfaceVariant"
                android:layout_marginEnd="@dimen/margin_small">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtTotalBorn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Cunnis.TitleSmall"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/parturition_total_born"
                    style="@style/TextAppearance.Cunnis.LabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="@dimen/padding_small"
                android:background="?attr/colorSurfaceVariant"
                android:layout_marginHorizontal="@dimen/margin_small">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtBornAlive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Cunnis.TitleSmall"
                    android:textColor="@color/cunnis_success" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/parturition_born_alive"
                    style="@style/TextAppearance.Cunnis.LabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="@dimen/padding_small"
                android:background="?attr/colorSurfaceVariant"
                android:layout_marginHorizontal="@dimen/margin_small">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtBornDead"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Cunnis.TitleSmall"
                    android:textColor="@color/cunnis_error" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/parturition_born_dead"
                    style="@style/TextAppearance.Cunnis.LabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="@dimen/padding_small"
                android:background="?attr/colorSurfaceVariant"
                android:layout_marginStart="@dimen/margin_small">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/txtWeaned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Cunnis.TitleSmall"
                    android:textColor="?attr/colorSecondary" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/parturition_weaned"
                    style="@style/TextAppearance.Cunnis.LabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

        </LinearLayout>

        <!-- Notes -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/txtNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            style="@style/TextAppearance.Cunnis.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

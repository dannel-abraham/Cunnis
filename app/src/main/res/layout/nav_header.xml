<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:orientation="vertical"
    android:background="@color/cunnis_control_normal"
    android:gravity="bottom"
    android:padding="@dimen/margin_medium">

    <ImageView
        android:id="@+id/imgNavHeader"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@mipmap/ic_launcher_round"
        android:contentDescription="@string/app_name"
        android:layout_marginBottom="@dimen/margin_small" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/txtNavFarmName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="18sp"
        android:textColor="@color/cunnis_white"
        android:fontFamily="sans-serif-medium" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/txtNavSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/drawer_header_subtitle"
        android:textSize="14sp"
        android:textColor="#B0FFFFFF" />

</LinearLayout>

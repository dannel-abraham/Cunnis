<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/margin_large">

    <!-- Exit Reason -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilExitReason"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/exit_reason">

        <AutoCompleteTextView
            android:id="@+id/actExitReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Exit Date -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilExitDate"
        style="@style/Widget.Cunnis.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/exit_date"
        android:layout_marginTop="@dimen/margin_medium">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtExitDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:inputType="none"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Exit Notes -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilExitNotes"
        style="@style/Widget.Cunnis.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/exit_notes"
        android:layout_marginTop="@dimen/margin_medium">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtExitNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Sale Price (visible only when exit reason is SOLD) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSalePrice"
        style="@style/Widget.Cunnis.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_medium"
        android:visibility="gone"
        app:startIconDrawable="@drawable/ic_expense"
        app:helperText="@string/exit_sale_price">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtSalePrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/exit_sale_price"
            android:inputType="numberDecimal" />

    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
